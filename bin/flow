#!/usr/bin/env bun
/**
 * `flow` — the shell wrapper for tmux-driven pipelines.
 *
 *   flow setup [--upgrade] [--force] [--source <path>]
 *                                      global install
 *   flow new <description>             create a tmux window + initial state
 *   flow ls [--cost [--detail]]        list active pipelines
 *   flow attach <name>                 tmux attach -t flow:<name>  (alias: a)
 *   flow done <name> | --all-merged    kill window + remove state
 *   flow migrate [--apply] [--scan <p>] [--include-orchestrator]
 *
 * Per-verb argument parsing lives in `bin/lib/<verb>.ts` as `run<Verb>Cli`.
 * Each shim short-circuits `--help` / `-h` before producing side-effects so
 * `flow new --help` (and friends) print usage instead of slugifying the flag
 * into a phantom pipeline.
 */

import { runAttachCli } from "./lib/attach";
import { runCompletion } from "./lib/completion";
import { printTopHelp, printVerbHelp } from "./lib/help";
import { runDoneCli } from "./lib/done";
import { runLsCli } from "./lib/ls";
import { runMigrateCli } from "./lib/migrate";
import { runNewCli } from "./lib/new";
import { runSetupCli } from "./lib/setup-args";
import { runVersionCli } from "./lib/version";
import { isVerb } from "./lib/verbs";

async function main(): Promise<number> {
  const [, , verb, ...rest] = process.argv;

  if (!verb) {
    printTopHelp();
    return 0;
  }

  if (isVerb(verb)) {
    return await runVerb(verb, rest);
  }

  console.error(`flow: unknown verb '${verb}'`);
  console.error(`run 'flow --help' for available verbs.`);
  return 1;
}

async function runVerb(verb: string, args: string[]): Promise<number> {
  switch (verb) {
    case "--help":
    case "-h":
    case "help":
      return runHelpVerb(args);
    case "setup":
      return runSetupCli(args);
    case "new":
      return runNewCli(args);
    case "attach":
    case "a":
      return runAttachCli(args);
    case "done":
      return runDoneCli(args);
    case "ls":
      return await runLsCli(args);
    case "migrate":
      return runMigrateCli(args);
    case "completion":
      return runCompletion(args[0]);
    case "--version":
    case "-v":
    case "version":
      return runVersionCli(args);
  }
  return 1;
}

/**
 * `flow help` (no args) → top-level help.
 * `flow help <verb>`    → that verb's usage block.
 * `flow help <unknown>` → error, exit 1.
 *
 * Self-references (`help`, `--help`, `-h`) collapse to top-level. Aliases
 * (`a` → `attach`, `-v` / `--version` → `version`) canonicalize to the
 * verb name registered in `HELP_TEXT`.
 */
function runHelpVerb(args: string[]): number {
  if (args.length === 0) {
    printTopHelp();
    return 0;
  }
  const target = args[0];
  if (target === "help" || target === "--help" || target === "-h") {
    printTopHelp();
    return 0;
  }
  const canonical =
    target === "a"
      ? "attach"
      : target === "-v" || target === "--version"
        ? "version"
        : target;
  return printVerbHelp(canonical);
}

main().then((code) => process.exit(code));

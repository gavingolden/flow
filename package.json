{
  "name": "flow",
  "version": "1.0.0",
  "description": "Multi-phase AI agent dev orchestration: triage → plan → implement → verify → CI → review → merge",
  "type": "module",
  "files": [
    "bin",
    "templates"
  ],
  "scripts": {
    "typecheck:scripts": "tsc -p tsconfig.scripts.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --check .",
    "verify": "npm run typecheck:scripts && npm run test && npm run lint"
  },
  "dependencies": {
    "picomatch": "^4.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/picomatch": "^3.0.1",
    "bun-types": "^1.1.38",
    "execa": "^9.5.1",
    "prettier": "3.8.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}

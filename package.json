{
  "name": "flow",
  "version": "0.0.1",
  "description": "Multi-phase AI agent dev orchestration: triage → plan → implement → verify → CI → review → merge",
  "type": "module",
  "files": [
    "bin",
    "templates"
  ],
  "scripts": {
    "typecheck:scripts": "tsc -p tsconfig.scripts.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run typecheck:scripts && npm run test"
  },
  "dependencies": {
    "execa": "^9.5.1",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "bun-types": "^1.1.38",
    "typescript": "^5.7.2",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}

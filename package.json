{
  "name": "flow",
  "version": "0.0.1",
  "description": "Multi-phase AI agent dev orchestration: triage → plan → implement → verify → CI → review → merge",
  "type": "module",
  "bin": {
    "flow": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "gray-matter": "^4.0.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
